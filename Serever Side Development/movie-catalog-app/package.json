{
  "name": "movie-catalog-app",
  "version": "1.0.0",
  "description": "Full-stack movie catalog application with AI",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "inquirer": "^9.2.11",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
